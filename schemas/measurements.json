{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aorticai.local/schemas/measurements.json",
  "title": "AorticAI Measurements Artifact",
  "type": "object",
  "required": ["measurements", "constraints"],
  "properties": {
    "measurements": {
      "type": "object",
      "required": [
        "annulus_equivalent_diameter_mm",
        "annulus_area_mm2",
        "annulus_perimeter_mm",
        "sinus_diameter_mm",
        "stj_diameter_mm",
        "ascending_aorta_diameter_mm",
        "coronary_height_left_mm",
        "coronary_height_right_mm",
        "leaflet_effective_height_mm",
        "calcium_burden_ml"
      ],
      "properties": {
        "annulus_equivalent_diameter_mm": { "$ref": "common.json#/$defs/ScalarMeasurement" },
        "annulus_area_mm2": { "$ref": "common.json#/$defs/ScalarMeasurement" },
        "annulus_perimeter_mm": { "$ref": "common.json#/$defs/ScalarMeasurement" },
        "sinus_diameter_mm": { "$ref": "common.json#/$defs/ScalarMeasurement" },
        "stj_diameter_mm": { "$ref": "common.json#/$defs/ScalarMeasurement" },
        "ascending_aorta_diameter_mm": { "$ref": "common.json#/$defs/ScalarMeasurement" },
        "coronary_height_left_mm": { "$ref": "common.json#/$defs/ScalarMeasurement" },
        "coronary_height_right_mm": { "$ref": "common.json#/$defs/ScalarMeasurement" },
        "leaflet_effective_height_mm": { "$ref": "common.json#/$defs/ScalarMeasurement" },
        "calcium_burden_ml": { "$ref": "common.json#/$defs/ScalarMeasurement" }
      },
      "additionalProperties": true
    },
    "measurements_raw": {
      "type": "object",
      "properties": {
        "sinus_of_valsalva": {
          "type": "object",
          "properties": {
            "uncertainty_flag": {
              "type": "string",
              "enum": [
                "NONE",
                "MISSING_INPUT",
                "DETECTION_FAILED",
                "LOW_CONFIDENCE",
                "ANATOMY_CONSTRAINT_VIOLATION",
                "OUT_OF_RANGE",
                "IMAGE_QUALITY_LIMITATION",
                "MODEL_INCONSISTENCY",
                "PLACEHOLDER_ONLY",
                "NOT_AVAILABLE"
              ]
            },
            "constraint_note": { "type": "string" }
          },
          "additionalProperties": true
        },
        "stj": {
          "type": "object",
          "properties": {
            "uncertainty_flag": {
              "type": "string",
              "enum": [
                "NONE",
                "MISSING_INPUT",
                "DETECTION_FAILED",
                "LOW_CONFIDENCE",
                "ANATOMY_CONSTRAINT_VIOLATION",
                "OUT_OF_RANGE",
                "IMAGE_QUALITY_LIMITATION",
                "MODEL_INCONSISTENCY",
                "PLACEHOLDER_ONLY",
                "NOT_AVAILABLE"
              ]
            },
            "constraint_note": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "measurements_regularized": {
      "type": "object",
      "properties": {
        "sinus_of_valsalva": {
          "type": "object",
          "properties": {
            "uncertainty_flag": {
              "type": "string",
              "enum": [
                "NONE",
                "MISSING_INPUT",
                "DETECTION_FAILED",
                "LOW_CONFIDENCE",
                "ANATOMY_CONSTRAINT_VIOLATION",
                "OUT_OF_RANGE",
                "IMAGE_QUALITY_LIMITATION",
                "MODEL_INCONSISTENCY",
                "PLACEHOLDER_ONLY",
                "NOT_AVAILABLE"
              ]
            },
            "constraint_note": { "type": "string" }
          },
          "additionalProperties": true
        },
        "stj": {
          "type": "object",
          "properties": {
            "uncertainty_flag": {
              "type": "string",
              "enum": [
                "NONE",
                "MISSING_INPUT",
                "DETECTION_FAILED",
                "LOW_CONFIDENCE",
                "ANATOMY_CONSTRAINT_VIOLATION",
                "OUT_OF_RANGE",
                "IMAGE_QUALITY_LIMITATION",
                "MODEL_INCONSISTENCY",
                "PLACEHOLDER_ONLY",
                "NOT_AVAILABLE"
              ]
            },
            "constraint_note": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "required": [
        "sinus_annulus_relation",
        "stj_sinus_relation",
        "commissure_symmetry",
        "coronary_height_assessment"
      ],
      "properties": {
        "sinus_annulus_relation": { "$ref": "common.json#/$defs/ClinicalGate" },
        "stj_sinus_relation": { "$ref": "common.json#/$defs/ClinicalGate" },
        "commissure_symmetry": { "$ref": "common.json#/$defs/ClinicalGate" },
        "coronary_height_assessment": { "$ref": "common.json#/$defs/ClinicalGate" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
