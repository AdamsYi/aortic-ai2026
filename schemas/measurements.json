{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aorticai.local/schemas/measurements.json",
  "title": "AorticAI Measurements Artifact",
  "type": "object",
  "$defs": {
    "SimpleScalarMeasurement": {
      "type": "object",
      "required": ["value", "unit", "evidence", "uncertainty"],
      "properties": {
        "value": { "type": ["number", "string", "boolean", "null"] },
        "unit": { "type": "string" },
        "evidence": {
          "type": "object",
          "required": ["method", "confidence"],
          "properties": {
            "method": { "type": "string" },
            "confidence": { "type": "number" },
            "source_type": { "type": "string" },
            "source_ref": { "type": "string" }
          },
          "additionalProperties": true
        },
        "uncertainty": {
          "type": "object",
          "required": ["flag", "clinician_review_required"],
          "properties": {
            "flag": { "type": "string" },
            "clinician_review_required": { "type": "boolean" },
            "message": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "required": [
    "annulus_equivalent_diameter_mm",
    "annulus_short_diameter_mm",
    "annulus_long_diameter_mm",
    "annulus_area_mm2",
    "annulus_perimeter_mm",
    "sinus_diameter_mm",
    "stj_diameter_mm",
    "ascending_aorta_diameter_mm",
    "lvot_diameter_mm",
    "coronary_height_left_mm",
    "coronary_height_right_mm",
    "calcium_burden_ml",
    "leaflet_effective_height_mm",
    "leaflet_coaptation_height_mm",
    "leaflet_geometric_height_mm"
  ],
  "properties": {
    "annulus_equivalent_diameter_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "annulus_short_diameter_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "annulus_long_diameter_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "annulus_area_mm2": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "annulus_perimeter_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "sinus_diameter_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "stj_diameter_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "ascending_aorta_diameter_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "lvot_diameter_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "coronary_height_left_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "coronary_height_right_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "calcium_burden_ml": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "leaflet_effective_height_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "leaflet_coaptation_height_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "leaflet_geometric_height_mm": { "$ref": "#/$defs/SimpleScalarMeasurement" },
    "_conversion_meta": { "type": "object" },
    "_pipeline_raw": { "type": "object" }
  },
  "additionalProperties": true
}
