{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aorticai.local/schemas/aortic_root_computational_model.json",
  "title": "AorticRootComputationalModel",
  "type": "object",
  "required": [
    "model_id",
    "case_id",
    "coordinate_system",
    "centerline",
    "annulus_ring",
    "hinge_curve",
    "commissures",
    "sinus_peaks",
    "sinotubular_junction",
    "ascending_aorta_axis",
    "coronary_ostia",
    "leaflet_meshes",
    "quality_gates"
  ],
  "properties": {
    "model_id": { "type": "string" },
    "case_id": { "type": "string" },
    "coordinate_system": { "type": "string" },
    "centerline": { "$ref": "centerline.json" },
    "annulus_ring": {
      "type": "object",
      "required": ["origin_world", "normal_world", "ring_points_world", "evidence", "uncertainty"],
      "properties": {
        "origin_world": { "$ref": "common.json#/$defs/Vector3" },
        "normal_world": { "$ref": "common.json#/$defs/Vector3" },
        "ring_points_world": { "type": "array", "items": { "$ref": "common.json#/$defs/Vector3" } },
        "evidence": { "$ref": "common.json#/$defs/Evidence" },
        "uncertainty": { "$ref": "common.json#/$defs/Uncertainty" }
      },
      "additionalProperties": true
    },
    "hinge_curve": {
      "type": "object",
      "required": ["points_world", "evidence", "uncertainty"],
      "properties": {
        "points_world": { "type": "array", "items": { "$ref": "common.json#/$defs/Vector3" } },
        "evidence": { "$ref": "common.json#/$defs/Evidence" },
        "uncertainty": { "$ref": "common.json#/$defs/Uncertainty" }
      },
      "additionalProperties": true
    },
    "commissures": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["name", "point_world", "evidence", "uncertainty"],
        "properties": {
          "name": { "type": "string" },
          "point_world": { "$ref": "common.json#/$defs/Vector3" },
          "evidence": { "$ref": "common.json#/$defs/Evidence" },
          "uncertainty": { "$ref": "common.json#/$defs/Uncertainty" }
        },
        "additionalProperties": true
      }
    },
    "sinus_peaks": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["name", "point_world", "evidence", "uncertainty"],
        "properties": {
          "name": { "type": "string" },
          "point_world": { "$ref": "common.json#/$defs/Vector3" },
          "evidence": { "$ref": "common.json#/$defs/Evidence" },
          "uncertainty": { "$ref": "common.json#/$defs/Uncertainty" }
        },
        "additionalProperties": true
      }
    },
    "sinotubular_junction": {
      "type": "object",
      "required": ["origin_world", "normal_world", "evidence", "uncertainty"],
      "properties": {
        "origin_world": { "$ref": "common.json#/$defs/Vector3" },
        "normal_world": { "$ref": "common.json#/$defs/Vector3" },
        "evidence": { "$ref": "common.json#/$defs/Evidence" },
        "uncertainty": { "$ref": "common.json#/$defs/Uncertainty" }
      },
      "additionalProperties": true
    },
    "ascending_aorta_axis": {
      "type": "object",
      "required": ["origin_world", "direction_world", "evidence", "uncertainty"],
      "properties": {
        "origin_world": { "$ref": "common.json#/$defs/Vector3" },
        "direction_world": { "$ref": "common.json#/$defs/Vector3" },
        "evidence": { "$ref": "common.json#/$defs/Evidence" },
        "uncertainty": { "$ref": "common.json#/$defs/Uncertainty" }
      },
      "additionalProperties": true
    },
    "coronary_ostia": {
      "type": "object",
      "required": ["left", "right"],
      "properties": {
        "left": {
          "type": "object",
          "required": ["status", "point_world", "evidence", "uncertainty"],
          "properties": {
            "status": { "type": "string" },
            "clinician_review_required": { "type": "boolean" },
            "point_world": { "anyOf": [{ "$ref": "common.json#/$defs/Vector3" }, { "type": "null" }] },
            "evidence": { "$ref": "common.json#/$defs/Evidence" },
            "uncertainty": { "$ref": "common.json#/$defs/Uncertainty" }
          },
          "additionalProperties": true
        },
        "right": {
          "type": "object",
          "required": ["status", "point_world", "evidence", "uncertainty"],
          "properties": {
            "status": { "type": "string" },
            "clinician_review_required": { "type": "boolean" },
            "point_world": { "anyOf": [{ "$ref": "common.json#/$defs/Vector3" }, { "type": "null" }] },
            "evidence": { "$ref": "common.json#/$defs/Evidence" },
            "uncertainty": { "$ref": "common.json#/$defs/Uncertainty" }
          },
          "additionalProperties": true
        },
        "clinician_review_required": { "type": "boolean" },
        "expected_height_mm": { "type": "number" }
      },
      "additionalProperties": true
    },
    "reference_sections": {
      "type": "object",
      "properties": {
        "geometry_stats": {
          "type": "object",
          "properties": {
            "regularization_applied": { "type": "boolean" },
            "regularization_reason": { "type": "string" },
            "primary_spacing_error_deg": { "type": "number" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "leaflet_meshes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["cusp_label", "mesh_path", "evidence", "uncertainty"],
        "properties": {
          "cusp_label": { "type": "string" },
          "mesh_path": { "type": "string" },
          "evidence": { "$ref": "common.json#/$defs/Evidence" },
          "uncertainty": { "$ref": "common.json#/$defs/Uncertainty" }
        },
        "additionalProperties": true
      }
    },
    "quality_gates": {
      "type": "object",
      "required": ["sinus_annulus_relation", "stj_sinus_relation", "commissure_symmetry", "coronary_height_assessment", "notes"],
      "properties": {
        "sinus_annulus_relation": { "$ref": "common.json#/$defs/ClinicalGate" },
        "stj_sinus_relation": { "$ref": "common.json#/$defs/ClinicalGate" },
        "commissure_symmetry": { "$ref": "common.json#/$defs/ClinicalGate" },
        "coronary_height_assessment": { "$ref": "common.json#/$defs/ClinicalGate" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
