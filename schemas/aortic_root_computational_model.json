{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aorticai.local/schemas/aortic_root_computational_model.json",
  "title": "AorticRootComputationalModel",
  "type": "object",
  "required": [
    "model_type",
    "centerline",
    "annulus_ring",
    "hinge_curve",
    "commissures",
    "sinus_peaks",
    "sinotubular_junction",
    "ascending_aorta_axis",
    "coronary_ostia",
    "leaflet_meshes"
  ],
  "properties": {
    "model_type": { "type": "string" },
    "centerline": {
      "type": "object",
      "required": ["point_count", "points_world"],
      "properties": {
        "point_count": { "type": "integer", "minimum": 1 },
        "points_world": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          }
        }
      },
      "additionalProperties": true
    },
    "annulus_ring": {
      "type": "object",
      "required": ["center_world", "normal_world", "equivalent_diameter_mm"],
      "properties": {
        "center_world": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "normal_world": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "equivalent_diameter_mm": { "type": "number" }
      },
      "additionalProperties": true
    },
    "hinge_curve": {
      "type": "object",
      "required": ["point_count", "points_world"],
      "properties": {
        "point_count": { "type": "integer", "minimum": 1 },
        "points_world": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          }
        }
      },
      "additionalProperties": true
    },
    "commissures": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "world"],
        "properties": {
          "id": { "type": "string" },
          "world": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          }
        },
        "additionalProperties": true
      }
    },
    "sinus_peaks": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "world"],
        "properties": {
          "id": { "type": "string" },
          "world": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          }
        },
        "additionalProperties": true
      }
    },
    "sinotubular_junction": {
      "type": "object",
      "required": ["center_world", "normal_world", "equivalent_diameter_mm"],
      "properties": {
        "center_world": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "normal_world": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "equivalent_diameter_mm": { "type": "number" }
      },
      "additionalProperties": true
    },
    "ascending_aorta_axis": {
      "type": "object",
      "required": ["start_world", "end_world"],
      "properties": {
        "start_world": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "end_world": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        }
      },
      "additionalProperties": true
    },
    "coronary_ostia": {
      "type": "object",
      "required": ["left", "right"],
      "properties": {
        "left": {
          "type": "object",
          "required": ["status", "clinician_review_required"],
          "properties": {
            "status": { "type": "string" },
            "clinician_review_required": { "type": "boolean" },
            "height_mm": { "type": ["number", "null"] },
            "ostium_world": {
              "anyOf": [
                {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3,
                  "maxItems": 3
                },
                { "type": "null" }
              ]
            }
          },
          "additionalProperties": true
        },
        "right": {
          "type": "object",
          "required": ["status", "clinician_review_required"],
          "properties": {
            "status": { "type": "string" },
            "clinician_review_required": { "type": "boolean" },
            "height_mm": { "type": ["number", "null"] },
            "ostium_world": {
              "anyOf": [
                {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3,
                  "maxItems": 3
                },
                { "type": "null" }
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "leaflet_meshes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["leaflet_id", "name", "status"],
        "properties": {
          "leaflet_id": { "type": ["string", "number"] },
          "name": { "type": "string" },
          "status": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
