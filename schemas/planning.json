{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aorticai.local/schemas/planning.json",
  "title": "AorticAI Planning Artifact",
  "type": "object",
  "required": ["tavi", "vsrr", "pears"],
  "properties": {
    "tavi": {
      "type": "object",
      "required": [
        "annulus_area_mm2",
        "annulus_perimeter_mm",
        "annulus_diameter_short_mm",
        "annulus_diameter_long_mm",
        "coronary_height_left_mm",
        "coronary_height_right_mm",
        "sinus_width_mm",
        "stj_diameter_mm",
        "area_derived_valve_size",
        "coronary_risk_flag",
        "valve_calcium_burden"
      ],
      "properties": {
        "annulus_area_mm2": { "type": "number" },
        "annulus_perimeter_mm": { "type": "number" },
        "annulus_diameter_short_mm": { "type": "number" },
        "annulus_diameter_long_mm": { "type": "number" },
        "coronary_height_left_mm": { "type": ["number", "null"] },
        "coronary_height_right_mm": { "type": ["number", "null"] },
        "sinus_width_mm": { "type": "number" },
        "stj_diameter_mm": { "type": "number" },
        "area_derived_valve_size": {
          "type": "object",
          "required": [
            "reference_nominal_sizes_mm",
            "nearest_nominal_size_mm",
            "area_derived_diameter_mm",
            "method"
          ],
          "properties": {
            "reference_nominal_sizes_mm": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 1
            },
            "nearest_nominal_size_mm": { "type": "number" },
            "area_derived_diameter_mm": { "type": "number" },
            "method": { "type": "string" }
          },
          "additionalProperties": true
        },
        "coronary_risk_flag": { "type": "boolean" },
        "valve_calcium_burden": {
          "type": "object",
          "required": ["threshold_hu", "calc_voxels", "calc_volume_ml", "method"],
          "properties": {
            "threshold_hu": { "type": "number" },
            "calc_voxels": { "type": "number" },
            "calc_volume_ml": { "type": "number" },
            "method": { "type": "string" }
          },
          "additionalProperties": true
        },
        "area_derived_valve_size_metadata": { "type": "object" },
        "coronary_risk_flag_metadata": { "type": "object" }
      },
      "additionalProperties": true
    },
    "vsrr": {
      "type": "object",
      "required": [
        "annulus_diameter_mm",
        "sinus_diameter_mm",
        "stj_diameter_mm",
        "lvot_diameter_mm",
        "recommended_graft_size_mm",
        "annulus_stj_mismatch_mm",
        "coaptation_height_mm",
        "effective_height_mean_mm",
        "coaptation_reserve_mm"
      ],
      "properties": {
        "annulus_diameter_mm": { "type": "number" },
        "sinus_diameter_mm": { "type": "number" },
        "stj_diameter_mm": { "type": "number" },
        "lvot_diameter_mm": { "type": "number" },
        "recommended_graft_size_mm": { "type": "number" },
        "annulus_stj_mismatch_mm": { "type": "number" },
        "coaptation_height_mm": { "type": "number" },
        "effective_height_mean_mm": { "type": "number" },
        "coaptation_reserve_mm": { "type": "number" },
        "recommended_graft_size_metadata": { "type": "object" },
        "coaptation_reserve_metadata": { "type": "object" }
      },
      "additionalProperties": true
    },
    "pears": {
      "type": "object",
      "required": [
        "root_external_geometry",
        "root_external_reference_diameter_mm",
        "support_segment_length_mm",
        "annulus_plane"
      ],
      "properties": {
        "root_external_geometry": {
          "type": "object",
          "required": [
            "annulus_reference_mm",
            "sinus_reference_mm",
            "stj_reference_mm"
          ],
          "properties": {
            "annulus_reference_mm": { "type": "number" },
            "sinus_reference_mm": { "type": "number" },
            "stj_reference_mm": { "type": "number" }
          },
          "additionalProperties": true
        },
        "root_external_reference_diameter_mm": { "type": "number" },
        "support_segment_length_mm": { "type": "number" },
        "annulus_plane": { "type": "object" },
        "root_external_geometry_metadata": { "type": "object" },
        "device_mesh_export_metadata": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
