{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aorticai.local/schemas/quality_gates.json",
  "title": "AorticAI Quality Gates",
  "type": "object",
  "required": [
    "sinus_annulus_relation",
    "stj_sinus_relation",
    "commissure_symmetry",
    "coronary_height_assessment",
    "notes"
  ],
  "properties": {
    "sinus_annulus_relation": { "$ref": "common.json#/$defs/ClinicalGate" },
    "stj_sinus_relation": { "$ref": "common.json#/$defs/ClinicalGate" },
    "commissure_symmetry": { "$ref": "common.json#/$defs/ClinicalGate" },
    "coronary_height_assessment": { "$ref": "common.json#/$defs/ClinicalGate" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "description": "Clinical reasonableness checks: sinus vs annulus, STJ vs sinus, commissure balance, and coronary height assessment. These are graded clinical judgments rather than rigid automatic hard failures."
}
