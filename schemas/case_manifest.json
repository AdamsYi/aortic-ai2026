{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aorticai.local/schemas/case_manifest.json",
  "title": "AorticAI Default Case Manifest",
  "type": "object",
  "required": [
    "case_id",
    "case_role",
    "display_name",
    "placeholder",
    "not_real_cta",
    "imaging_index",
    "artifact_index",
    "mesh_index",
    "report_index",
    "qa_index",
    "capabilities"
  ],
  "properties": {
    "case_id": { "type": "string" },
    "case_role": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "display_name": {
      "type": "object",
      "required": ["zh-CN", "en"],
      "properties": {
        "zh-CN": { "type": "string" },
        "en": { "type": "string" }
      },
      "additionalProperties": false
    },
    "placeholder": { "type": "boolean" },
    "not_real_cta": { "type": "boolean" },
    "build_version": { "type": "string" },
    "imaging_index": { "type": "object" },
    "artifact_index": { "type": "object" },
    "mesh_index": { "type": "object" },
    "report_index": { "type": "object" },
    "qa_index": { "type": "object" },
    "capabilities": {
      "type": "object",
      "properties": {
        "cpr": { "$ref": "common.json#/$defs/CapabilityState" },
        "coronary_ostia": { "$ref": "common.json#/$defs/CapabilityState" },
        "leaflet_geometry": { "$ref": "common.json#/$defs/CapabilityState" },
        "pears_geometry": { "$ref": "common.json#/$defs/CapabilityState" }
      },
      "required": ["cpr", "coronary_ostia", "leaflet_geometry", "pears_geometry"],
      "additionalProperties": false
    },
    "planning_summary": { "type": "object" },
    "study_meta": {
      "type": "object",
      "description": "Acquisition metadata for the source CTA. Required for the clinical data-quality gate.",
      "properties": {
        "slice_thickness_mm": { "type": ["number", "null"] },
        "voxel_spacing_mm": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "is_tavi_root_covered": { "type": ["boolean", "null"] },
        "is_vsrr_root_covered": { "type": ["boolean", "null"] },
        "is_pears_covered": { "type": ["boolean", "null"] },
        "is_root_covered": { "type": ["boolean", "null"] },
        "is_iliofemoral_covered": { "type": ["boolean", "null"] },
        "is_cropped": { "type": ["boolean", "null"] },
        "contrast_phase": {
          "type": ["string", "null"],
          "enum": ["non_contrast", "arterial", "venous", "unknown", null]
        },
        "fov_mm": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "blood_pool_hu_mean": { "type": ["number", "null"] },
        "blood_pool_hu_source": {
          "type": ["string", "null"],
          "enum": ["mask", "central-fallback", "central-by-design", null]
        }
      },
      "additionalProperties": true
    },
    "data_quality": {
      "type": "object",
      "description": "Computed quality gate. UI MUST refuse sizing workflow when passes_sizing_gate is false.",
      "required": ["passes_sizing_gate", "failure_reasons"],
      "properties": {
        "passes_sizing_gate": { "type": "boolean" },
        "allowed_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["TAVI", "VSRR", "PEARS"]
          }
        },
        "failure_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "advisories": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "mesh_qa": {
      "type": "object",
      "description": "Per-mesh geometry QA. Keys are mesh logical names (e.g. aortic_root, ascending_aorta, leaflet_L).",
      "additionalProperties": {
        "type": "object",
        "required": ["tri_count"],
        "properties": {
          "tri_count": { "type": "integer", "minimum": 0 },
          "non_manifold_edges": { "type": ["integer", "null"] },
          "watertight": { "type": ["boolean", "null"] },
          "aspect_ratio_p95": { "type": ["number", "null"] },
          "mesh_kind": { "type": ["string", "null"], "enum": ["solid", "tube_segment", null] },
          "boundary_loop_count": { "type": ["integer", "null"] },
          "boundary_loops_all_closed": { "type": ["boolean", "null"] },
          "passes_gate": { "type": ["boolean", "null"] },
          "failure_reasons": {
            "type": "array",
            "items": { "type": "string" }
          },
          "skipped_reason": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": true
      }
    },
    "quality_gates_summary": {
      "type": "object",
      "required": [
        "sinus_annulus_relation",
        "stj_sinus_relation",
        "commissure_symmetry",
        "coronary_height_assessment"
      ],
      "properties": {
        "sinus_annulus_relation": { "$ref": "common.json#/$defs/ClinicalGate" },
        "stj_sinus_relation": { "$ref": "common.json#/$defs/ClinicalGate" },
        "commissure_symmetry": { "$ref": "common.json#/$defs/ClinicalGate" },
        "coronary_height_assessment": { "$ref": "common.json#/$defs/ClinicalGate" }
      },
      "additionalProperties": false
    },
    "uncertainty_summary": { "type": "object" }
  },
  "additionalProperties": true
}
