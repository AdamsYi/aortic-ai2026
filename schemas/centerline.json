{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aorticai.local/schemas/centerline.json",
  "title": "AorticAI Centerline Artifact",
  "type": "object",
  "required": [
    "method",
    "point_count",
    "annulus_index",
    "stj_index",
    "sinus_peak_index",
    "ascending_reference_index",
    "skeletonization",
    "quality"
  ],
  "properties": {
    "method": { "type": "string" },
    "point_count": { "type": "integer", "minimum": 1 },
    "annulus_index": { "type": "integer", "minimum": 0 },
    "stj_index": { "type": "integer", "minimum": 0 },
    "sinus_peak_index": { "type": "integer", "minimum": 0 },
    "ascending_reference_index": { "type": "integer", "minimum": 0 },
    "skeletonization": { "type": "string" },
    "quality": {
      "type": "object",
      "required": [
        "point_count",
        "total_length_mm",
        "mean_radius_mm",
        "min_radius_mm",
        "smoothness_score",
        "method",
        "quality_flag",
        "uncertainty_flag"
      ],
      "properties": {
        "point_count": { "type": "integer", "minimum": 1 },
        "total_length_mm": { "type": "number" },
        "mean_radius_mm": { "type": "number" },
        "min_radius_mm": { "type": "number" },
        "smoothness_score": { "type": "number" },
        "method": { "type": "string" },
        "quality_flag": { "type": "string" },
        "uncertainty_flag": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
