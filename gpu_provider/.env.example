# inline: return output in HTTP response
# callback: return accepted immediately and post result to callback.url
PROVIDER_RESPONSE_MODE=inline

# Optional model id included in result json
MODEL_TAG=nnunet-provider-v1

# Optional: hard limit for decoded input bytes
MAX_INPUT_BYTES=83886080

# Optional timeout when posting callback
CALLBACK_TIMEOUT_SECONDS=20

# Optional: run real command (must produce output_path file)
# placeholders: {input_path} {output_path} {job_id} {study_id}
# INFER_CMD=python /workspace/run_infer.py --input {input_path} --output {output_path}
