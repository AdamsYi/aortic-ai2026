{
  "name": "aortic-ai-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "node scripts/build/build_workstation.mjs",
    "build:default-case": "node scripts/build/build_default_case_bundle.mjs",
    "build:workstation": "npm run build:web",
    "build": "npm run build:web",
    "dev": "npm run build:web && wrangler dev",
    "deploy": "npm run build:web && wrangler deploy",
    "deploy:preview": "npm run build:web && wrangler dev",
    "deploy:versioned": "npm run deploy",
    "check:workstation": "tsc -p tsconfig.workstation.json --noEmit",
    "check:control-plane-clean": "bash scripts/diagnostic/assert_control_plane_clean.sh",
    "d1:migrate:local": "wrangler d1 migrations apply aortic_meta --local",
    "d1:migrate:remote": "wrangler d1 migrations apply aortic_meta --remote",
    "e2e:user": "node scripts/diagnostic/e2e_user_flow.mjs",
    "acceptance:online": "node scripts/diagnostic/run_online_workstation_acceptance.mjs",
    "test:schema": "node --import tsx --test tests/schema_validation.test.ts",
    "test:unit": "node --import tsx --test tests/default_case_api.test.ts tests/legacy_pipeline_run.test.ts tests/legacy_viewer_baseline.test.ts tests/failure_modes.test.ts tests/build_version_hash.test.ts tests/security_headers.test.ts tests/performance_smoke.test.ts tests/case_result_truth.test.ts",
    "test:e2e": "playwright test",
    "test": "npm run test:schema && npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@cloudflare/workers-types": "^4.20260303.0",
    "@types/three": "^0.183.1",
    "ajv": "^8.17.1",
    "esbuild": "^0.27.4",
    "playwright-core": "^1.58.2",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "wrangler": "^4.12.0"
  },
  "dependencies": {
    "@cornerstonejs/core": "^4.19.2",
    "@cornerstonejs/dicom-image-loader": "^4.19.2",
    "@cornerstonejs/nifti-volume-loader": "^4.19.2",
    "@cornerstonejs/tools": "^4.19.2",
    "dicom-parser": "^1.8.21",
    "fflate": "^0.8.2",
    "three": "^0.179.1"
  }
}
